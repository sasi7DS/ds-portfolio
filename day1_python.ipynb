    "import numpy as np\n",
    "numbers = [10, 20, 30, 40, 50]\n",
    "arr = np.array(numbers)\n",
    "\n",
    "print(\"Array:\", arr)\n",
    "print(\"Mean:\", arr.mean())\n",
    "print(\"Max:\", arr.max())\n",
    "print(\"Min:\", arr.min())\n",
    "print(\"Sum:\", arr.sum())"
   ]
  }
